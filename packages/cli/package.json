{
  "name": "@linear-agent/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "linear": "dist/bin/linear.js",
    "li": "dist/bin/linear.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin/linear.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "dev": "tsx src/bin/linear.ts"
  },
  "dependencies": {
    "@linear-agent/linear-core": "workspace:*",
    "@linear-agent/skills-catalog": "workspace:*",
    "@linear-agent/tui": "workspace:*",
    "commander": "^14.0.3",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
