{
  "name": "@wiseiodev/linear-cli",
  "version": "1.4.0",
  "type": "module",
  "bin": {
    "linear": "dist/bin/linear.js",
    "li": "dist/bin/linear.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && chmod +x dist/bin/linear.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "dev": "tsx src/bin/linear.ts"
  },
  "dependencies": {
    "@linear/sdk": "^77.0.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "keytar": "^7.9.0",
    "open": "^11.0.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@wiseiodev/linear-core": "workspace:*",
    "@wiseiodev/skills-catalog": "workspace:*",
    "@wiseiodev/tui": "workspace:*",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  }
}
